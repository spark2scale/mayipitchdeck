# ─── Required ────────────────────────────────────────────────────────────────

# Your Azure OpenAI resource endpoint (no trailing slash)
# e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# Your Azure OpenAI API key
AZURE_OPENAI_KEY=

# The deployment name you created in Azure AI Studio
# e.g. gpt-5.4-deployment   OR   computer-use-preview-deployment
AZURE_OPENAI_DEPLOYMENT=

# API version that supports the computer / computer_use_preview tool
# GA new tool:     2025-04-01-preview
# Legacy preview:  2024-12-01-preview
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ─── Optional ─────────────────────────────────────────────────────────────────

# Set to "true" if your deployment uses the older computer-use-preview model
# (this switches to the legacy request shape automatically)
AZURE_USE_LEGACY_TOOL=false

# Comma-separated list of additional allowed CORS origins (e.g. Railway preview URLs)
ADDITIONAL_ORIGINS=

# Port (Railway sets this automatically; defaults to 3001 for local dev)
PORT=3001
